{
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Job Execution Rate by Stage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(platform_jobs_executed_total[5m])) by (stage, status)",
          "legendFormat": "{{stage}} {{status}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Job Duration p95 by Stage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(platform_jobs_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "{{stage}} p95"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Job Failure Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(platform_jobs_executed_total{status=\"failed\"}[15m])) / sum(rate(platform_jobs_executed_total[15m]))",
          "legendFormat": "Failure Rate"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["platform", "jobs"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Platform — Jobs",
  "uid": "platform-jobs",
  "version": 1
}
