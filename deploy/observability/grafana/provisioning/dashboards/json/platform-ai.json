{
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "AI Call Rate by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(platform_ai_calls_total[5m])) by (provider, model, status)",
          "legendFormat": "{{provider}}/{{model}} {{status}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "AI Call Duration p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(platform_ai_call_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "{{provider}} p95"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Token Usage (Input / Output)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(platform_ai_tokens_total[5m])) by (type, provider)",
          "legendFormat": "{{type}} {{provider}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["platform", "ai"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Platform — AI",
  "uid": "platform-ai",
  "version": 1
}
