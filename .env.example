# ===================================================================
# PLATFORM ENVIRONMENT CONFIGURATION
# Copy to .env.local and fill in values. Never commit .env.local.
# Run `pnpm setup` after filling in required values.
# ===================================================================

# --- Foundation ---
APP_ENV="development"                       # development | staging | production
NODE_ENV="development"
LOG_LEVEL="debug"                           # trace | debug | info | warn | error
PORT="3000"
DOMAIN="dev.platform.example.co.za"        # No trailing slash; subdomains are derived
ADMIN_EMAIL="admin@example.co.za"

# --- Client-exposed (Next.js) ---
NEXT_PUBLIC_APP_ENV="development"
NEXT_PUBLIC_APP_URL="https://dev.platform.example.co.za"
NEXT_PUBLIC_BRAND_NAME="Platform"

# --- Adapter Selection ---
# Change these to switch the backend implementation. No code changes required.
DATABASE_DRIVER="postgres"                  # postgres | mssql | mongo
IDENTITY_DRIVER="builtin"                   # builtin | entra | oidc | saml
STORAGE_DRIVER="local"                      # local | s3 | azure_blob
EMAIL_DRIVER="smtp"                         # smtp | ses | sendgrid
EVENTBUS_DRIVER="redis"                     # inproc | redis | postgres
JOBS_DRIVER="postgres"                      # postgres | mssql | redis
AI_DRIVER="claude_cli"                      # claude_cli | anthropic_api | azure_openai
VECTORSTORE_DRIVER="pgvector"               # pgvector | qdrant | azure_search | inproc

# --- Postgres (only if DATABASE_DRIVER=postgres) ---
POSTGRES_URL="postgres://platform:changeme@localhost:5432/platform_dev"
POSTGRES_DIRECT_URL="postgres://platform:changeme@localhost:5432/platform_dev"
POSTGRES_POOL_SIZE="10"

# --- MSSQL (only if DATABASE_DRIVER=mssql) ---
# MSSQL_SERVER=""
# MSSQL_PORT="1433"
# MSSQL_DATABASE=""
# MSSQL_USER=""
# MSSQL_PASSWORD=""
# MSSQL_ENCRYPT="true"

# --- Mongo (only if DATABASE_DRIVER=mongo) ---
# MONGO_URL=""
# MONGO_DATABASE=""

# --- Identity: built-in (only if IDENTITY_DRIVER=builtin) ---
AUTH_SECRET="<generate with: openssl rand -base64 48>"  # Min 32 chars; must be unique per env
AUTH_SESSION_DURATION_DAYS="30"

# --- Identity: OIDC / Entra (only if IDENTITY_DRIVER=oidc or entra) ---
# OIDC_ISSUER_URL=""
# OIDC_CLIENT_ID=""
# OIDC_CLIENT_SECRET=""
# OIDC_REDIRECT_URI=""

# --- Identity: SAML (only if IDENTITY_DRIVER=saml) ---
# SAML_METADATA_URL=""
# SAML_CERT=""

# --- Storage: local (only if STORAGE_DRIVER=local) ---
STORAGE_LOCAL_PATH="/var/platform/storage"

# --- Storage: S3-compatible (only if STORAGE_DRIVER=s3) ---
# Works with AWS S3, MinIO, Backblaze B2, Wasabi, etc.
# STORAGE_S3_ENDPOINT=""          # Omit for AWS; set for self-hosted (e.g. http://minio:9000)
# STORAGE_S3_REGION=""
# STORAGE_S3_BUCKET=""
# STORAGE_S3_ACCESS_KEY=""
# STORAGE_S3_SECRET_KEY=""
# STORAGE_S3_PATH_STYLE="false"   # true for MinIO / self-hosted

# --- Storage: Azure Blob (only if STORAGE_DRIVER=azure_blob) ---
# STORAGE_AZURE_ACCOUNT=""
# STORAGE_AZURE_KEY=""
# STORAGE_AZURE_CONTAINER=""

# --- Email: SMTP (only if EMAIL_DRIVER=smtp) ---
EMAIL_FROM="noreply@example.co.za"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"                         # true for port 465 (implicit TLS)

# --- Email: SES (only if EMAIL_DRIVER=ses) ---
# SES_REGION=""

# --- Email: SendGrid (only if EMAIL_DRIVER=sendgrid) ---
# SENDGRID_API_KEY=""

# --- Redis (required if EVENTBUS_DRIVER=redis or JOBS_DRIVER=redis) ---
REDIS_URL="redis://localhost:6379"

# --- AI / Worker ---
WORKER_POLL_INTERVAL_MS="2000"
WORKER_JOB_TIMEOUT_MS="300000"
WORKER_MAX_CONCURRENCY="1"
CLAUDE_CLI_PATH="claude"                    # Path to the Claude CLI binary
CLAUDE_CLI_TIMEOUT_MS="120000"
# ANTHROPIC_API_KEY=""                      # Only if AI_DRIVER=anthropic_api
# AZURE_OPENAI_ENDPOINT=""                  # Only if AI_DRIVER=azure_openai
# AZURE_OPENAI_KEY=""

# --- Backup / Restic ---
# Required in prod; optional in dev/staging (falls back to local-volume-only backup)
# RESTIC_REPOSITORY=""                      # e.g. b2:bucket-name:/path
# RESTIC_PASSWORD=""                        # Restic encryption passphrase
# B2_ACCOUNT_ID=""                          # Backblaze B2 application key ID
# B2_ACCOUNT_KEY=""                         # Backblaze B2 application key

# --- CLA (GitHub Actions) ---
# CLA_TOKEN is a GitHub PAT with repo + workflow scope, stored as a repo secret.
# Required for the CLA Assistant workflow to write the signatures file.
# CLA_TOKEN=""
