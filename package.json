{
  "name": "platform",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "boundaries": "tsx scripts/check-boundaries.mts",
    "boundaries:staged": "tsx scripts/check-boundaries.mts --staged",
    "clean": "turbo clean && rimraf \"packages/*/dist\" \"packages/ports/*/dist\" \"apps/*/dist\" \"apps/*/.next\"",
    "check-workspace": "tsx scripts/check-workspace.mts",
    "new-package": "tsx scripts/new-package.mts",
    "verify-clean-tree": "tsx scripts/verify-clean-tree.mts",
    "env:check": "tsx packages/config/src/env/validate.mts",
    "env:completeness": "tsx scripts/check-env-completeness.mts",
    "setup": "tsx scripts/setup-local.mts",
    "setup:local-db": "docker compose -f infra/docker/local.yml up -d",
    "teardown:local-db": "docker compose -f infra/docker/local.yml down -v",
    "obs:up": "docker compose -f deploy/observability/compose.yml up -d",
    "obs:down": "docker compose -f deploy/observability/compose.yml down",
    "obs:logs": "docker compose -f deploy/observability/compose.yml logs -f",
    "obs:status": "docker compose -f deploy/observability/compose.yml ps",
    "db:reset:dev": "tsx scripts/db-reset-dev.mts",
    "db:generate": "echo 'db:generate will be implemented in Objective 4'",
    "seed:dev": "tsx packages/db/seed/dev.mts",
    "seed:staging": "tsx packages/db/seed/staging.mts",
    "seed:prod": "tsx packages/db/seed/prod.mts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "dotenv": "16.5.0",
    "@commitlint/config-conventional": "19.8.1",
    "@types/node": "22.15.0",
    "@typescript-eslint/eslint-plugin": "8.32.0",
    "@typescript-eslint/parser": "8.32.0",
    "dependency-cruiser": "16.10.2",
    "eslint": "9.26.0",
    "eslint-plugin-perfectionist": "4.13.0",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-security": "3.0.1",
    "husky": "9.1.7",
    "lint-staged": "15.4.3",
    "prettier": "3.5.3",
    "rimraf": "6.0.1",
    "tsx": "4.19.4",
    "turbo": "2.4.4",
    "typescript": "5.8.3"
  }
}
