{
  "name": "@platform/adapter-persistence-postgres",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "clean": "rimraf dist",
    "db:migrate": "tsx src/migrate.ts apply",
    "db:migrate:status": "tsx src/migrate.ts status",
    "db:migrate:create": "tsx src/migrate.ts create",
    "db:migrate:down": "tsx src/migrate.ts down",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@platform/ports-ai-artifacts": "workspace:*",
    "@platform/ports-observability": "workspace:*",
    "@platform/ports-persistence": "workspace:*",
    "@platform/ports-search": "workspace:*",
    "@platform/ports-storage": "workspace:*",
    "@platform/ports-workspace-assets": "workspace:*",
    "neverthrow": "8.2.0",
    "pg": "^8.13.0",
    "drizzle-orm": "^0.44.0",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@platform/adapter-observability-memory": "workspace:*",
    "@platform/config": "workspace:*",
    "@platform/core": "workspace:*",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.0",
    "fast-check": "^3.23.0",
    "rimraf": "6.0.1",
    "tsx": "4.19.4",
    "vitest": "3.2.3"
  }
}
