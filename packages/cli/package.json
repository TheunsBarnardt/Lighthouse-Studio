  },
  "devDependencies": {
    "@platform/config": "workspace:*",
    "@types/node": "22.15.0",
    "rimraf": "6.0.1",
    "tsup": "^8.4.0",
    "typescript": "5.8.3",
    "vitest": "3.2.3"
  }
}
