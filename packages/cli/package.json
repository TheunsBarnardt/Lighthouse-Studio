{
  "name": "@platform/cli",
  "version": "0.1.0",
  "description": "Platform CLI — type generation, schema sync, project bootstrap",
  "license": "AGPL-3.0",
  "type": "module",
  "bin": {
    "pdm": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
