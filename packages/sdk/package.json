{
  "name": "@platform/sdk",
  "version": "0.1.0",
  "description": "The official TypeScript SDK for the Platform",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs",
      "types": "./dist/auth/index.d.ts"
    },
    "./data": {
      "import": "./dist/data/index.js",
      "require": "./dist/data/index.cjs",
      "types": "./dist/data/index.d.ts"
    },
    "./realtime": {
      "import": "./dist/realtime/index.js",
      "require": "./dist/realtime/index.cjs",
      "types": "./dist/realtime/index.d.ts"
    },
    "./storage": {
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs",
      "types": "./dist/storage/index.d.ts"
    },
    "./query": {
      "import": "./dist/query/index.js",
      "require": "./dist/query/index.cjs",
      "types": "./dist/query/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "docs:api": "typedoc --out ../../docs/api/sdk src/index.ts"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@platform/config": "workspace:*",
    "@types/node": "22.15.0",
    "@types/ws": "^8.5.14",
    "rimraf": "6.0.1",
    "tsup": "^8.4.0",
    "typescript": "5.8.3",
    "vitest": "3.2.3"
  }
}
