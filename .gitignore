# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
.next/
out/
build/
*.tsbuildinfo

# Turbo
.turbo/

# Testing
coverage/
.nyc_output/

# Environment files — never commit secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories
.idea/
*.swp
*.swo
*.suo
*.user
*.userosscache
*.sln.docstates

# OS
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Temporary files
*.tmp
*.temp

# Private Claude memory (not for sharing)
.claude/memory-private/

# Claude Code worktree checkouts (session-local, never committed)
.claude/worktrees/

# Compiled test artifacts (tests should never emit alongside sources)
packages/*/tests/**/*.js
packages/*/tests/**/*.js.map
packages/*/tests/**/*.d.ts
packages/*/tests/**/*.d.ts.map
